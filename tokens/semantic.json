  "radius": {
    "button": { "$value": "{radius.full}", "$type": "dimension", "$description": "Pill buttons — locked" },
    "card": { "$value": "{radius.lg}", "$type": "dimension", "$description": "Card corners" },
    "tag": { "$value": "{radius.full}", "$type": "dimension", "$description": "Tag pills" },
    "input": { "$value": "{radius.md}", "$type": "dimension", "$description": "Input fields" }
