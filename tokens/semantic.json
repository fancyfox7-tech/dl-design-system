      "lg": { "$value": "{space.8}", "$type": "dimension", "$description": "Component-to-component" },
      "xl": { "$value": "{space.12}", "$type": "dimension", "$description": "Section break" }
    },
    "layout": {
      "section": { "$value": "{space.20}", "$type": "dimension", "$description": "Between sections" },
      "hero": { "$value": "{space.24}", "$type": "dimension", "$description": "Hero padding" },
      "content": { "$value": "{space.16}", "$type": "dimension", "$description": "Layout whitespace" }
    }
